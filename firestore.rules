rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Reusable, Hardened Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      // In compliance with mandatory verified email guidelines
      return isSignedIn() && (request.auth.token.email_verified == true);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Validation Blueprint for the "Ad" Entity
    function isValidAd(data) {
      return data.id is string 
        && data.id.size() <= 128
        && data.userId == request.auth.uid
        && data.title is string 
        && data.title.size() <= 200
        && data.rawText is string 
        && data.rawText.size() <= 5000
        && data.hook is string 
        && data.hook.size() <= 2000
        && data.scenes is list 
        && data.scenes.size() <= 30
        && (data.speechPace == 'fast' || data.speechPace == 'normal' || data.speechPace == 'slow')
        && (data.createdAt is int || data.createdAt is float)
        && (!('theme' in data) || data.theme is string)
        && (!('used' in data) || data.used is bool);
    }

    // 4. Secure Match Block for local/cloud Ads
    match /ads/{adId} {
      
      // Path validation and owner check for single get
      allow get: if isSignedIn() && isOwner(existing().userId) && isValidId(adId);
      
      // Query Enforcer: Force secure query on owner field, preventing query scraping
      allow list: if isSignedIn() && existing().userId == request.auth.uid;

      // Create rule using the validation helper
      allow create: if isEmailVerified() 
        && isValidId(adId) 
        && isValidAd(incoming())
        && incoming().userId == request.auth.uid;

      // Update validation enforcing immutable fields
      allow update: if isEmailVerified()
        && isValidId(adId)
        && isValidAd(incoming())
        && isOwner(existing().userId)
        && incoming().userId == existing().userId
        && incoming().id == existing().id
        && incoming().createdAt == existing().createdAt;

      // Delete validation
      allow delete: if isEmailVerified()
        && isValidId(adId)
        && isOwner(existing().userId);
    }
  }
}
